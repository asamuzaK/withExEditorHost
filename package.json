{
  "name": "withexeditorhost",
  "description": "Native messaging host for withExEditor",
  "author": "asamuzaK",
  "license": "MIT",
  "homepage": "https://github.com/asamuzaK/withExEditorHost",
  "bugs": "https://github.com/asamuzaK/withExEditorHost/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asamuzaK/withExEditorHost.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^14.0.3",
    "semver-parser": "^4.1.8",
    "undici": "^7.24.6",
    "web-ext-native-msg": "^8.0.14"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "eslint": "^9.39.4",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "genversion": "^3.2.0",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "neostandard": "^0.13.0",
    "sinon": "^21.0.3"
  },
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    },
    "serialize-javascript": "^7.0.4"
  },
  "scripts": {
    "build": "npm run genversion && npm run lint && npm run test",
    "genversion": "genversion --es6 --semi ./modules/version.js",
    "lint": "eslint . --fix",
    "setup": "node ./index.js setup",
    "start": "node ./index.js",
    "test": "c8 --reporter=text mocha --exit test/*.test.js"
  },
  "version": "10.0.0"
}
